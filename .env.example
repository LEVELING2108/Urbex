# ===========================================
# LLM API Configuration (Choose ONE provider)
# ===========================================

# Option 1: OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Option 2: Google Gemini (https://aistudio.google.com/apikey) - FREE TIER
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Option 3: Groq (https://console.groq.com/keys) - FREE TIER
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Option 4: Together AI (https://api.together.ai/) - $25 FREE CREDIT
TOGETHER_API_KEY=your_together_api_key_here
TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf

# Active Provider (openai, gemini, groq, together, mock)
ACTIVE_PROVIDER=mock

# Mock Mode (set to true to use rule-based moderation without any API)
USE_MOCK_MODE=true

# Embedding Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Vector Store Configuration
FAISS_INDEX_PATH=./data/faiss_index
VECTOR_STORE_TYPE=faiss

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# Moderation Thresholds
TOXICITY_THRESHOLD=0.7
HIGH_CONFIDENCE_THRESHOLD=0.85
LOW_CONFIDENCE_THRESHOLD=0.5

# Performance Configuration
MAX_RETRIEVAL_DOCS=5
RESPONSE_TIMEOUT=10
CACHE_TTL=3600

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/urbex.log

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Database (optional for audit logs)
DATABASE_URL=sqlite:///./data/moderation_logs.db

# Security
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=["http://localhost:3000"]

# Feature Flags
ENABLE_BATCH_PROCESSING=true
ENABLE_STREAMING=false
ENABLE_DETAILED_LOGGING=true
